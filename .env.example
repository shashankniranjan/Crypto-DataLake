BML_SYMBOL=BTCUSDT
BML_ROOT_DIR=./data
BML_STATE_DB=./state/ingestion_state.sqlite
BML_SAFETY_LAG_MINUTES=3
BML_MAX_FFILL_MINUTES=60
BML_REST_TIMEOUT_SECONDS=20
BML_REST_MAX_RETRIES=5
BML_REST_CONCURRENCY=4
BML_LIVE_EVENT_RETENTION_HOURS=12
BML_LIVE_HEARTBEAT_RETENTION_DAYS=14
BML_LIVE_CLEANUP_INTERVAL_MINUTES=30
BML_LIVE_CLEANUP_VACUUM_INTERVAL_HOURS=24
BML_LOG_LEVEL=INFO
BML_API_ENABLE_NATIVE_BINANCE_TF_CANDLES=true
BML_API_CANDLE_FETCH_MODE=native_preferred
BML_API_ALLOW_LEGACY_1M_FALLBACK=true
BML_API_ALLOW_PARTIAL_RESPONSE_WITH_NOTES=true
BML_API_INCLUDE_DEPRECATED_FIELDS=false
BML_API_ENABLE_LOCAL_SYMBOL_FASTPATH=true
BML_API_LOCAL_PREFERRED_SYMBOLS=BTCUSDT
BML_API_LOCAL_SYMBOL_REQUIRE_FULL_COVERAGE=false
BML_API_LOCAL_SYMBOL_ALLOW_BINANCE_PATCH=true
BML_API_ENABLE_BTC_COMPLEXITY_GUARD=true
BML_API_BTC_LOCAL_MAX_1M_BARS=500
BML_API_BTC_LOCAL_MAX_3M_BARS=300
BML_API_BTC_LOCAL_MAX_HIGHER_TF_BARS=200
BML_API_BTC_FORCE_BINANCE_FOR_HEAVY_HIGHER_TF=true
